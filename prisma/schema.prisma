generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User { 
  id              Int     @id @default(autoincrement()) 
  username        String  @unique
  password        String
  ign             String
  mlbbId          String
  currentRank     String  @default("Warrior")
  peakRank        String  @default("Warrior")
  role            String  @default("Mid")
  totalMatches    Int    @default(0)
  winRate         Float  @default(0)
  fbLink          String?
  avatarUrl       String?
  scrims          Scrim[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
} 

model Scrim {
  id              Int     @id @default(autoincrement())
  squadType       String  // "Full Squad" or "Open Squad"
  teamName        String
  teamLogo        String?
  minRank         String
  maxRank         String
  gameFormat      String  // "Games" or "Best of"
  gameCount       Int     // 1-100
  date            String
  time            String
  author          User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId        Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Post { 
  id        Int     @id @default(autoincrement()) 
  title     String
  content   String?
  published Boolean @default(false) 

} 