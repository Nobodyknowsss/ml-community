generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User { 
  id              Int     @id @default(autoincrement()) 
  username        String  @unique
  password        String
  name            String?
  mlbbId          String
  currentRank     String  @default("Warrior")
  currentRankStars Int    @default(0)
  peakRank        String  @default("Warrior")
  peakRankStars   Int    @default(0)
  role            String  @default("Mid")
  totalMatches    Int    @default(0)
  winRate         Float  @default(0)
  fbLink          String?
  avatarUrl       String?
  posts           Post[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
} 

model Post { 
  id        Int     @id @default(autoincrement()) 
  title     String
  content   String?
  published Boolean @default(false) 
  author    User    @relation(fields: [authorId], references: [id]) 
  authorId  Int

} 